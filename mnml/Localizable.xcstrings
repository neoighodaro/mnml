{
  "sourceLanguage" : "en",
  "strings" : {
    "-%@" : {
      "comment" : "A countdown timer showing how much time is left in the current chapter. The argument is the remaining time in the chapter.",
      "isCommentAutoGenerated" : true,
      "shouldTranslate" : false
    },
    "“%@” and its downloaded file will be deleted. This can't be undone." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„%@“ und die heruntergeladene Datei werden gelöscht. Dies kann nicht rückgängig gemacht werden."
          }
        }
      }
    },
    "“%@” will be removed from all your devices. This can't be undone." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„%@“ wird von all deinen Geräten entfernt. Dies kann nicht rückgängig gemacht werden."
          }
        }
      }
    },
    "“%@” will start over from the beginning." : {
